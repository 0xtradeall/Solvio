modules = ["nodejs-20"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd /home/runner/workspace && fuser -k 5000/tcp 2>/dev/null || true && NEXT_TELEMETRY_DISABLED=1 NODE_OPTIONS='--max-old-space-size=1024' npm run dev"
waitForPort = 5000

[[ports]]
localPort = 5000
externalPort = 80
